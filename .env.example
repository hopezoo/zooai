# 复制此文件为 .env 并填写实际值：cp .env.example .env
# 或直接使用生产模板：cp .env.prod .env
# 将项目根目录 configs/ 完整复制到本目录下（与 docker-compose.yml 同级）
#   cp -r ../../../configs ./configs
#
# configs/app.yaml 及各产品 YAML 中的 ${VAR:default} 占位符，
# 在容器启动时由此 .env（通过 env_file）注入的环境变量替换
# docker-compose.yml 的 environment: 块中同名变量优先级更高，会覆盖 .env 中的值

# ==================== Docker Compose 镜像 ====================
REGISTRY=hopezoo
# latest 始终指向最近一次 make docker-release 推送的镜像；也可指定如 v0.1.0
VERSION=latest

# ==================== MySQL ====================
# Docker Compose 内置 MySQL 容器的 root 密码
MYSQL_ROOT_PASSWORD=root
# 应用连接配置（compose 内 environment: 会将 MYSQL_HOST 强制设为 mysql:3306）
MYSQL_HOST=mysql:3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=
MYSQL_MAX_IDLE_CONNS=100
MYSQL_MAX_OPEN_CONNS=100
MYSQL_LOG_LEVEL=4

# ==================== Redis ====================
# compose 内 environment: 会将 REDIS_HOST 强制设为 redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=50

# ==================== 服务运行模式 ====================
SERVER_MODE=debug
LOG_LEVEL=debug
LOG_FORMAT=console

# ==================== JWT ====================
JWT_KEY=changeme
JWT_CLIENT_SECRET=your-client-secret
JWT_ADMIN_SECRET=your-admin-secret
JWT_TIMEOUT=24h
JWT_MAX_REFRESH=24h

# ==================== 邮件（SMTP）====================
MAIL_SERVICE_TYPE=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SENDGRID_API_KEY=
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=

# ==================== 支付（易支付）====================
EPAY_PROVIDER=epay
EPAY_API_URL=https://qzt2.issss.top
EPAY_CREATE_URI=/mapi.php
EPAY_QUERY_URI=/api.php
EPAY_PID=
EPAY_KEY=
EPAY_NOTIFY_URL=
EPAY_RETURN_URL=
EPAY_TEST_MODE=false
# Epay 使用自签名证书时设为 true（如 x509: certificate signed by unknown authority）
EPAY_INSECURE_SKIP_VERIFY=false

# ==================== Bootstrap 超级管理员（首次部署后建议关闭）====================
BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=changeme
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_NICKNAME=Admin

# ==================== 部署控制 ====================
# 设为 1 时跳过数据库迁移（deploy.sh 中不执行 migrate）
# 适用于：外部已有 DB 且单独管理迁移、或迁移已由其他流程执行
SKIP_MIGRATE=0

# ==================== 其他 ====================
SNOWFLAKE_NODE_ID=1

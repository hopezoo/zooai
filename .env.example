# 复制此文件为 .env 并填写实际值：cp .env.example .env
# 首次部署若需自动创建超级管理员，设 BOOTSTRAP_ADMIN_ENABLED=true 并填写账号密码，迁移完成后建议改回 false
#
# 镜像约定：gateway 独立 hopezoo/gateway:linux-<版本>；biz 后端 hopezoo/<产品>:backend-<端>-linux-<版本>；aishop 前端 hopezoo/aishop:frontend-<端>-linux-<版本>；migrate hopezoo/zooai:migrate-linux-<版本>
# 例：hopezoo/gateway:linux-v1.0.0、hopezoo/aishop:backend-admin-linux-v1.0.0、hopezoo/aishop:frontend-admin-linux-v1.0.0

REGISTRY=hopezoo
VERSION=latest

# MySQL（compose 内服务名为 mysql:3306，此处可覆盖）
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=zooai
# 应用与迁移通过 configs/app.yaml 的 ${MYSQL_HOST} 等读取，若镜像内 app.yaml 使用占位符则生效
MYSQL_HOST=mysql:3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=root

# Redis（compose 内服务名为 redis:6379）
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT（client/admin 端密钥，按产品配置）
JWT_CLIENT_SECRET=your-client-secret
JWT_ADMIN_SECRET=your-admin-secret

# 首次部署可选：Bootstrap 超级管理员（迁移 064 在默认租户 default 下创建一名 super_admin）
# 创建成功后请将 BOOTSTRAP_ADMIN_ENABLED 改为 false
BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=changeme
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_NICKNAME=Admin
